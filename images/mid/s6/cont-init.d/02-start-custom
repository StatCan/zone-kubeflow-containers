#!/command/with-contenv bash

echo "--------------------Starting up--------------------"

# Setup directories
S6_ENV="/run/s6-env"
mkdir -p "${S6_ENV}"

# Export RStudio web path for JupyterHub
export RSERVER_WWW_ROOT_PATH="${NB_PREFIX}/rstudio"
echo "${RSERVER_WWW_ROOT_PATH}" > "${S6_ENV}/RSERVER_WWW_ROOT_PATH"

# Extract namespace from NB_PREFIX
export NB_NAMESPACE=$(echo "${NB_PREFIX}" | cut -d'/' -f3)
echo "${NB_NAMESPACE}" > "${S6_ENV}/NB_NAMESPACE"

# Store JWT token
export JWT="$(cat /var/run/secrets/kubernetes.io/serviceaccount/token)"
echo "${JWT}" > "${S6_ENV}/JWT"

# Add environment variables to R configuration
{
    echo "NB_PREFIX=${NB_PREFIX}"
    echo "NB_NAMESPACE=${NB_NAMESPACE}"
    echo "NLS_LANG=${NLS_LANG}"
    echo "SPARK_HOME=${SPARK_HOME}"
    printenv | grep -E "^(KUBERNETES_|svm_)"
} >> /opt/conda/lib/R/etc/Renviron

# Get Artifactory credentials
SERVICE_USER=$(kubectl get secret artifactory-creds -n "${NB_NAMESPACE}" --template={{.data.Username}} | base64 --decode)
SERVICE_TOKEN=$(kubectl get secret artifactory-creds -n "${NB_NAMESPACE}" --template={{.data.Token}} | base64 --decode)

# Configure package managers with Artifactory
configure_package_managers() {
    local user="$1"
    local token="$2"

    # Conda channels
    conda config --add channels "https://${user}:${token}@artifactory.cloud.statcan.ca/artifactory/conda-forge-remote/"
    conda config --add channels "https://${user}:${token}@artifactory.cloud.statcan.ca/artifactory/conda-pytorch-remote/"
    conda config --add channels "https://${user}:${token}@artifactory.cloud.statcan.ca/artifactory/conda-nvidia-remote/"
    conda config --remove channels 'defaults'
    conda config --remove channels conda-forge --system

    # Pip
    pip config set global.index-url "https://${user}:${token}@artifactory.cloud.statcan.ca/artifactory/api/pypi/pypi/simple"

    # Pixi (if not already configured)
    PIXI_CONFIG="/home/${NB_USER}/.pixi/config.toml"
    mkdir -p "$(dirname "${PIXI_CONFIG}")"
    [ ! -f "${PIXI_CONFIG}" ] && cat > "${PIXI_CONFIG}" <<EOF
default-channels = ["https://${user}:${token}@artifactory.cloud.statcan.ca/artifactory/conda-forge-remote/"]
EOF
}

configure_package_managers "${SERVICE_USER}" "${SERVICE_TOKEN}"

# Setup R configuration
setup_r_config() {
    local user="$1"
    local token="$2"
    local ubuntu_codename=$(lsb_release -cs)

    cat > /opt/conda/lib/R/etc/Rprofile.site <<EOF
options(jupyter.plot_mimetypes = c('text/plain', 'image/png', 'image/jpeg', 'image/svg+xml', 'application/pdf'))

# Dynamic PPM URL with credentials and Ubuntu codename
# Extract major.minor format (e.g., "4.5" from R version "4.5.1")
r_version <- paste0(R.version\$major, ".", strsplit(R.version\$minor, "\\\\.")[[1]][1])

ppm_url <- sprintf(
  "https://${user}:${token}@artifactory.cloud.statcan.ca/artifactory/zone-r-ppm-bin-${ubuntu_codename}-%s-remote",
  r_version
)

options(
  repos = c(
    CRAN = "https://cran.r-project.org/",
    ppm = ppm_url
  )
)

options(download.file.method = "wget")
Sys.setenv(R_LIBS_USER = paste0(Sys.getenv("HOME"), "/R/r-packages-",
                                R.version\$major, ".", R.version\$minor))
EOF
}

setup_r_config "${SERVICE_USER}" "${SERVICE_TOKEN}"

# Configure language
setup_language() {
    case "${KF_LANG}" in
        "en")
            export LANG="en_US.utf8"
            ;;
        "fr")
            export LANG="fr_FR"
            setup_french_ui
            ;;
        *)
            export LANG="en_US.utf8"  # Default to English
            ;;
    esac

    echo "${LANG}" > "${S6_ENV}/LANG"
    echo "Language configured to: ${LANG}"
}

setup_french_ui() {
    # JupyterLab French settings
    JUPYTER_LANG_FILE="/home/${NB_USER}/.jupyter/lab/user-settings/@jupyterlab/translation-extension/plugin.jupyterlab-settings"
    mkdir -p "$(dirname "${JUPYTER_LANG_FILE}")"
    [ ! -f "${JUPYTER_LANG_FILE}" ] && cat > "${JUPYTER_LANG_FILE}" <<'EOF'
{
   // Langue
   // @jupyterlab/translation-extension:plugin
   // Paramètres de langue.
   // ****************************************

   // Langue locale
   // Définit la langue d'affichage de l'interface. Exemples: 'es_CO', 'fr'.
   "locale": "fr"
}
EOF

    # VSCode French settings
    VSCODE_LANG_FILE="${CS_DEFAULT_HOME}/User/argv.json"
    mkdir -p "$(dirname "${VSCODE_LANG_FILE}")"
    [ ! -f "${VSCODE_LANG_FILE}" ] && echo '{"locale":"fr"}' > "${VSCODE_LANG_FILE}"
}

[ -n "${KF_LANG}" ] && setup_language

echo "--------------------Setup complete--------------------"
